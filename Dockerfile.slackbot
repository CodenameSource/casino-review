# slackbot: the market's Slack surface. Socket Mode — outbound only, no ports.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/slackbot ./cmd/slackbot && \
    CGO_ENABLED=0 go build -o /out/casino ./cmd/casino

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/slackbot /out/casino /usr/local/bin/
USER nobody
ENTRYPOINT ["slackbot"]
