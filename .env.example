# Copy to .env and fill in. Load with:  set -a; . ./.env; set +a
# (To just preview a GIF with no GitHub at all, run `go run . gen out.gif`.)

# Required
GITHUB_TOKEN=ghp_xxx          # read to monitor; WRITE (repo scope) to react + post comments + GIF asset
GITHUB_REPO=owner/repo        # the repo whose PRs are watched (a GitHub URL works too)

# Optional (defaults shown)
TRIGGER=/casino-review        # comment that starts a spin
REVIEWS=tsetso-review,dimoreview,gigareview   # candidates, no leading slash
POLL_INTERVAL=30s             # how often to poll for new comments
DISPLAY_DURATION=20s          # delay before the real review fires (the GIF stays + loops regardless)
ASSETS_BRANCH=casino-review-assets   # orphan branch the GIFs are committed to (no main-repo files)
ASSETS_TTL=720h               # prune committed GIFs older than this (720h = 30 days)
# ASSETS_REPO=CodenameSource/casino-review   # where to host the GIFs. Leave unset to use GITHUB_REPO.
                              # If GITHUB_REPO is PRIVATE, set this to a PUBLIC repo you own —
                              # private raw URLs carry a ~5-min token and the embed goes blank.
REACTION=rocket               # reaction marking a comment processed — also the dedup state
                              # (no local file). GitHub has no 8-ball; valid:
                              #   +1 -1 laugh confused heart hooray rocket eyes
