# Copy to .env. docker compose loads this via env_file; for local runs:
#   set -a; . ./.env; set +a
# (To just preview a GIF with no GitHub at all: `go run ./cmd/casino gen out.gif`.)

# Required
GITHUB_TOKEN=ghp_xxx          # read to monitor; WRITE (repo scope) to react + comment + commit GIFs
GITHUB_REPO=owner/repo        # the repo whose PRs are watched (a GitHub URL works too)

# Database (compose sets DATABASE_URL itself; set this only for local runs)
# DATABASE_URL=postgres://casino:casino@localhost:5432/casino
POSTGRES_PASSWORD=casino      # used by the compose postgres + service URLs

# Reviews
TRIGGER=/casino-review        # comment that starts a spin
REVIEWS=tsetso-review,dimoreview,gigareview,barbie-review   # legacy fallback: comma list, all dispatch engines
# REVIEWS_FILE=reviews.json   # typed registry (see reviews.example.json); overrides REVIEWS
                              # (compose mounts ./reviews.json at /config/reviews.json and sets this)

# Behavior (defaults shown)
POLL_INTERVAL=30s             # how often to poll for new comments
ORACLE_ENABLED=true           # auto-settle markets (bounty/merge-by on merge, findings-count from review, expiry→void)
ORACLE_POLL_INTERVAL=60s      # how often the resolution oracle scans open markets
                              # ^ preview with `casino oracle once` (dry-run) before trusting it; set false to disable
DISPLAY_DURATION=20s          # delay between posting the GIF and running the winning review
ASSETS_BRANCH=casino-review-assets   # orphan branch the GIFs are committed to (no main-repo files)
ASSETS_TTL=720h               # prune committed GIFs older than this (720h = 30 days)
# ASSETS_REPO=CodenameSource/casino-review   # PUBLIC repo hosting GIFs (required if GITHUB_REPO is private:
                              # private raw URLs carry a ~5-min token and the embed goes blank)
REACTION=rocket               # reaction marking a comment processed — also the dedup state
                              # valid: +1 -1 laugh confused heart hooray rocket eyes (no 8-ball, sorry)

# Runner
# WORKDIR=./work              # PR checkout scratch space (compose: /work volume)

# LLM reviewers (SUNSET — foundations kept for their return)
# ANTHROPIC_API_KEY=sk-ant-xxx
# CLAUDE_BIN=claude

# Slack (P2 market surface — Socket Mode, no public URL)
# SLACK_BOT_TOKEN=xoxb-...    # bot token: scopes chat:write, commands, channels:read
# SLACK_APP_TOKEN=xapp-...    # app-level token with connections:write (Socket Mode)
# SLACK_CHANNEL=#pr-casino    # the ONLY channel the bot honors (ID like C0123 also works)
# SLACK_ADMINS=U0123,U0456    # Slack user IDs allowed to lock/resolve/void markets
                              # (unset = those verbs disabled in Slack; CLI remains the admin path)

# Telemetry (optional)
# METRICS_ADDR=:9090          # prometheus /metrics (compose sets this per service)
# (The Postgres `events` table is the always-on scientific record. PostHog
#  behavioral analytics was dropped for now — it made builds too heavy on 1GB VMs.)
