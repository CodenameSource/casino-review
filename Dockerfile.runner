# runner: executes spin jobs — git for PR checkouts, node for TS analyzers
# (eslint/tsc via npx).
#
# LLM reviewers are SUNSET for now: when they return, reinstall the claude CLI
# here (npm install -g @anthropic-ai/claude-code, plus ripgrep) and provide
# ANTHROPIC_API_KEY in the environment.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/runner ./cmd/runner && \
    CGO_ENABLED=0 go build -o /out/casino ./cmd/casino

FROM node:20-alpine
RUN apk add --no-cache ca-certificates tzdata git && \
    mkdir -p /work && chown node:node /work
COPY --from=build /out/runner /out/casino /usr/local/bin/
ENV WORKDIR=/work
USER node
ENTRYPOINT ["runner"]
