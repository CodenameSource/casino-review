# core: trigger poller + coordinator. Small static image — no toolchain.
FROM golang:1.25-alpine AS build
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/core ./cmd/core && \
    CGO_ENABLED=0 go build -o /out/casino ./cmd/casino

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=build /out/core /out/casino /usr/local/bin/
USER nobody
ENTRYPOINT ["core"]
