{
  "reviews": [
    { "name": "tsetso-review", "engine": "dispatch" },
    { "name": "dimoreview", "engine": "dispatch" },
    { "name": "gigareview", "engine": "dispatch" },
    { "name": "barbie-review", "engine": "dispatch" },
    {
      "name": "paranoid-sec",
      "engine": "claude",
      "prompt_file": "/config/personas/paranoid-sec.md",
      "max_turns": 30,
      "timeout": "10m"
    }
  ],
  "addon": {
    "name": "static",
    "chance": 0.25,
    "analyzers": [
      {
        "cmd": ["npx", "--yes", "eslint", ".", "--format", "json"],
        "parser": "eslint",
        "timeout": "5m"
      },
      {
        "cmd": ["npx", "--yes", "tsc", "--noEmit"],
        "parser": "tsc",
        "timeout": "5m"
      }
    ]
  },
  "judges": [
    { "name": "judge-dread", "prompt_file": "/config/personas/judge-dread.md" }
  ]
}
